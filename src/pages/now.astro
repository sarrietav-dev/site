---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="What Sebastian Arrieta is doing now." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>Now — Sebastian Arrieta</title>
  </head>
  <body>
    <Nav />

    <div class="section">
      <div class="label">/now</div>
      <div class="content">
        <p>Here's what I'm focused on right now.</p>
      </div>
    </div>

    <footer>
      <p>Updated May 2026 · <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">what is a now page?</a></p>
    </footer>
  </body>
</html>

<style>
  .section {
    margin-bottom: 1.5rem;
  }

  .label {
    color: var(--color-label);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .content p {
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  footer {
    margin-top: 3rem;
    font-size: 0.8rem;
    color: var(--color-label);
  }

  footer a {
    color: var(--color-label);
  }
</style>
