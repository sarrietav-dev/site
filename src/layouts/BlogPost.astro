---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  pubDate: Date;
  description: string;
}

const { title, pubDate, description } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title} — Sebastian Arrieta</title>
  </head>
  <body>
    <Nav />
    <article>
      <header>
        <h1>{title}</h1>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </header>
      <slot />
    </article>
  </body>
</html>

<style>
  article header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-label);
  }

  article header h1 {
    margin-bottom: 0.5rem;
  }

  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  article :global(p) {
    margin-bottom: 1rem;
  }

  article :global(h2),
  article :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  article :global(ul),
  article :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  article :global(ul) {
    list-style-type: disc;
  }

  article :global(ol) {
    list-style-type: decimal;
  }

  article :global(li) {
    margin-bottom: 0.25rem;
    line-height: 1.6;
  }

  article :global(li > ul),
  article :global(li > ol) {
    margin-top: 0.25rem;
    margin-bottom: 0;
  }

  article :global(pre) {
    margin-bottom: 1rem;
  }

  article :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  article :global(:not(pre) > code) {
    background-color: var(--color-code-bg);
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }
</style>
